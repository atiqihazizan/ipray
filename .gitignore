# =============================================================================
# ipray – root .gitignore (v1 C/C++ + v2 Node/React/Electron)
# =============================================================================

# -----------------------------------------------------------------------------
# OS & metadata
# -----------------------------------------------------------------------------
.DS_Store
**/.DS_Store
.DS_Store?
**/.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride
Icon?
ehthumbs.db
Thumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Backup & temporary files (semua folder/fail backup jangan di-track)
# -----------------------------------------------------------------------------
backup/
**/backup/
* copy
* copy/
* copy.*
**/* copy
**/* copy/
**/* copy.*
**/data copy/
**/data copy/**
*.bak
*_bak
*_bak/
**/*_bak
**/*_bak/
* bak
* bak/
**/* bak
**/* bak/
*.backup
*.asal
*.tmp
*.temp
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# C/C++ – compiled & build (v1 macos, macos_raspi, windows)
# -----------------------------------------------------------------------------
*.d
*.slo
*.lo
*.o
*.obj
*.gch
*.pch
*.so
*.dylib
*.dll
*.lai
*.la
*.a
*.lib
*.exe
*.out
*.app
obj/
**/obj/
[Dd]ebug/
[Rr]elease/
[Bb]in/
[Oo]bj/
x64/
x86/
**/build/
**/CMakeFiles/
**/CMakeCache.txt
**/cmake_install.cmake
**/Makefile
**/compiler_depend.internal

# -----------------------------------------------------------------------------
# Xcode (v1 macos, macos_raspi)
# -----------------------------------------------------------------------------
*.xcodeproj
**/*.xcodeproj
*.xcworkspace
**/*.xcworkspace
xcuserdata/
**/xcuserdata/
DerivedData/
**/DerivedData/

# -----------------------------------------------------------------------------
# Visual Studio (v1 windows)
# -----------------------------------------------------------------------------
.vs/
**/.vs/
*.user
*.userosscache
*.sln.docstates
*.vcxproj
*.vcxproj.filters
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# -----------------------------------------------------------------------------
# Node / npm / yarn / pnpm (v2)
# -----------------------------------------------------------------------------
node_modules/
**/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.log
logs/
**/logs/

# -----------------------------------------------------------------------------
# Build outputs – JS/React/Vite/Electron (v2)
# -----------------------------------------------------------------------------
dist/
**/dist/
dist-ssr/
**/dist-ssr/
build/
**/build/
*.local
.vite/
**/.vite/
vite.config.js.timestamp-*
*.map
out/
**/out/
release/
**/release/
mac/
win/
linux/
*.dmg
*.blockmap
*.AppImage
*.deb
*.rpm
*.snap

# -----------------------------------------------------------------------------
# Environment & secrets (v2)
# -----------------------------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local
**/.env
**/.env.local
**/.env*.local

# -----------------------------------------------------------------------------
# Media / generated (optional – uncomment if repo terlalu besar)
# -----------------------------------------------------------------------------
# media/
# **/media/

# -----------------------------------------------------------------------------
# Editor & IDE
# -----------------------------------------------------------------------------
.idea/
**/.idea/
.vscode/*
!**/.vscode/extensions.json
!**/.vscode/settings.json
.cursorignore
**/.cursorignore
*.sublime-project
*.sublime-workspace
*.code-workspace

# -----------------------------------------------------------------------------
# Testing & coverage (v2)
# -----------------------------------------------------------------------------
coverage/
**/coverage/
.nyc_output/
**/.nyc_output/
*.lcov
.jest/
**/.jest/

# -----------------------------------------------------------------------------
# Cache & tooling
# -----------------------------------------------------------------------------
.cache/
**/.cache/
.parcel-cache/
**/.parcel-cache/
.eslintcache
**/.eslintcache
.stylelintcache
**/.stylelintcache
*.tsbuildinfo
**/*.tsbuildinfo

# -----------------------------------------------------------------------------
# Project-specific
# -----------------------------------------------------------------------------
history-development/
**/history-development/
*.pdn
