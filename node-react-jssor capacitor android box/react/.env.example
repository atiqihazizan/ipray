# Copy ke .env atau .env.production dan ubah nilai
# VITE_API_URL: asal HTTP pelayan Node (tanpa /api di akhir — akan ditambah automatik)
# VITE_SOCKET_URL: asal Socket.IO (biasanya sama port dengan API)

VITE_API_URL=http://192.168.1.100:3001
VITE_SOCKET_URL=http://192.168.1.100:3001

# Fallback lama (jika VITE_API_URL tidak ditetapkan):
# VITE_API_BASE=http://192.168.1.100:3001

# Kosong dalam production build = auto ikut hostname (selain DEV yang default localhost:3001)
