###########################
# AMIL MTA (HTML/JS Only)
###########################
server {
    server_name amil.masjidtuanabdullah.com;
    root /var/www/mta.manager/amil;
    
    listen 80;
    listen [::]:80;
    
    index index.html index.php;
    charset utf-8;
    access_log off;
    log_not_found off;
    sendfile off;
    server_tokens off;
    add_header X-Frame-Options "SAMEORIGIN";
    add_header X-Content-Type-Options "nosniff";
    
    location / {
        try_files $uri $uri/ /index.php?$query_string;
    }
    
    # PHP Processing
    location ~ \.php$ {
        fastcgi_pass unix:/var/run/php/php8.3-fpm.sock;
        fastcgi_index index.php;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        include fastcgi_params;
        fastcgi_intercept_errors on;
        fastcgi_buffering on;
        fastcgi_buffer_size 16k;
        fastcgi_buffers 4 16k;
    }
    
    # Cache control for static assets
    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg)$ {
        expires 30d;
        add_header Cache-Control "public, no-transform";
    }
    
    # Blok akses file tersembunyi
    location ~ /\.(?!well-known).* {
        deny all;
    }
    
    # Deny access to sensitive files
    location ~ \.(env|log|gitignore|git|htaccess|htpasswd|ini|conf|txt)$ {
        deny all;
    }
}

server {
    if ($host = admin.masjidtuanabdullah.com) {
        return 301 https://$host$request_uri;
    } # managed by Certbot

    listen 80;
    listen [::]:80;
    
    server_name admin.masjidtuanabdullah.com;
    return 404; # managed by Certbot
}

