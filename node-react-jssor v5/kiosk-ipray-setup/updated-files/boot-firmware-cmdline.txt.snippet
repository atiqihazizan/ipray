# --- Snippet untuk /boot/firmware/cmdline.txt ---
# Fail ini SATU BARIS. Pastikan ada parameter berikut (tambah jika tiada):
#   quiet loglevel=0 splash
#
# Contoh baris penuh (format sebenar bergantung pada Pi anda):
# console=tty1 root=PARTUUID=xxx rootfstype=ext4 rootwait quiet loglevel=0 splash
#
# Jangan buang parameter sedia ada (root=, rootwait, dll); hanya tambah quiet loglevel=0 splash.

quiet loglevel=0 splash
