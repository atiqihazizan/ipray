# --- Snippet untuk /etc/lightdm/lightdm.conf ---
# Dalam bahagian [Seat:*] (biasanya [Seat:*] atau [Seat:seat0]),
# pastikan baris berikut wujud dan tidak dikomen (#).
# Jika sudah ada baris serupa, ubah nilai mengikut di bawah.

[Seat:*]
pam-autologin-service=lightdm-autologin
autologin-user=ipray
autologin-user-timeout=0
autologin-session=rpd-x
user-session=rpd-x
greeter-session=pi-greeter-x
