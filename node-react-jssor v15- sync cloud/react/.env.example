# Optional: override API base dan Socket URL pada build time
# Copy ke .env dan ubah nilai jika perlu (npm run build guna nilai ini)

# Contoh: paksa semua build guna ipray.local untuk API/Socket
# VITE_API_BASE=http://ipray.local/api
# VITE_SOCKET_URL=http://ipray.local

# Kosong = auto ikut hostname (localhost / ipray.local / development)
